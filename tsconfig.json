{
  // compilerOptions: TypeScript 编译器的选项配置
  "compilerOptions": {
    "target": "ES2021",                      // 编译目标：ES2021（支持 String.replaceAll 等）
    "module": "ESNext",                      // 模块系统：最新的 ES 模块标准
    "lib": ["ES2021", "DOM", "DOM.Iterable"], // 类型库：ES2021 + DOM API + DOM 迭代器
    "skipLibCheck": true,                    // 跳过声明文件（.d.ts）的类型检查，加速编译
    "moduleResolution": "bundler",           // 模块解析策略：适配 Vite 等 bundler
    "allowImportingTsExtensions": true,      // 允许在 import 中使用 .ts 扩展名
    "isolatedModules": true,                 // 每个文件视为独立模块（Vite 编译要求）
    "moduleDetection": "force",              // 强制所有文件视为模块（即使没有 import/export）
    "noEmit": true,                          // 不生成编译输出（仅做类型检查，Vite 负责编译）
    "jsx": "preserve",                       // JSX 保留原样（Vue 使用，非 React）
    "strict": true,                          // 启用所有严格类型检查选项
    "noUnusedLocals": true,                  // 报告未使用的局部变量
    "noUnusedParameters": true,              // 报告未使用的函数参数
    "noFallthroughCasesInSwitch": true,      // switch 语句禁止 fallthrough
    // 路径别名：@/ 映射到 ./src/ 目录
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  // include: 需要编译的文件匹配模式
  "include": ["src/**/*.ts", "src/**/*.tsx", "src/**/*.vue"]
}
